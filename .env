# ==========================================================
# APPLICATION
# ==========================================================

APP_NAME=GenAI Data Engineering Platform
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=True

HOST=0.0.0.0
PORT=8000

# ==========================================================
# POSTGRESQL
# ==========================================================

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=genai_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/genai_platform

# ==========================================================
# APACHE KAFKA
# ==========================================================

KAFKA_BOOTSTRAP_SERVERS=kafka:9092

ORDER_TOPIC=orders
CUSTOMER_TOPIC=customers
PAYMENT_TOPIC=payments
PRODUCT_TOPIC=products
INVENTORY_TOPIC=inventory
CLICKSTREAM_TOPIC=clickstream

# ==========================================================
# SNOWFLAKE
# ==========================================================

SNOWFLAKE_ACCOUNT=your_account
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=GENAI_PLATFORM
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=ACCOUNTADMIN

# ==========================================================
# OLLAMA (LOCAL LLM)
# ==========================================================

OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# ==========================================================
# VECTOR DATABASE
# ==========================================================

FAISS_INDEX_PATH=./data/faiss

# ==========================================================
# DATA STORAGE
# ==========================================================

BRONZE_PATH=./data/bronze
SILVER_PATH=./data/silver
GOLD_PATH=./data/gold

# ==========================================================
# LOGGING
# ==========================================================

LOG_LEVEL=INFO
LOG_FORMAT=json

# ==========================================================
# AIRFLOW (Future Phase)
# ==========================================================

AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin

# ==========================================================
# PROMETHEUS (Future Phase)
# ==========================================================

PROMETHEUS_PORT=9090

# ==========================================================
# GRAFANA (Future Phase)
# ==========================================================

GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ==========================================================
# PYSPARK
# ==========================================================

SPARK_APP_NAME=GenAIDataEngineeringPlatform
SPARK_MASTER=local[*]

# ==========================================================
# DATA QUALITY
# ==========================================================

EXPECTATION_SUITE_NAME=default_suite

# ==========================================================
# PROJECT
# ==========================================================

PROJECT_NAME=GenAI Data Engineering Platform
